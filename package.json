{
  "name": "evolvo",
  "version": "0.2.0",
  "description": "Autonomous self-evolving TypeScript-style engineering system",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --test dist/test/**/*.test.js",
    "check": "pnpm exec tsc --noEmit",
    "pretest": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}